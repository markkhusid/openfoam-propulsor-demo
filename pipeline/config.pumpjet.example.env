# Example: literature-inspired demo pumpjet (design/geometry)
# Usage from repo root:
#   cp pipeline/config.pumpjet.example.env pipeline/config.env
#   # edit REPO_ROOT if not running from repo root
#   ./pipeline/run_all.sh pipeline/config.env

REPO_ROOT="${REPO_ROOT:-$PWD}"

CASE_DIR="${REPO_ROOT}/cases/pumpjet_demo"
ROTOR_STL="${REPO_ROOT}/design/geometry/rotor.stl"
STATOR_STLS="${REPO_ROOT}/design/geometry/duct_stator.stl"
STL_SCALE=1.0

ROTATION_MODE=mrf

RPM=900
ROT_AXIS="0 1 0"
ROT_ORIGIN="0 0 0"
U_INF="0 -1.5 0"
NU=1e-6
RHO_INF=1
CHAR_DIAMETER=0.2

DOMAIN_UPSTREAM_D=1.5
DOMAIN_DOWNSTREAM_D=3.0
DOMAIN_RADIUS_D=1.8
ROTZONE_RADIUS_FACTOR=1.15
ROTZONE_HALF_LENGTH_D=0.45

MESH_PRESET=demo
NPROCS=1
N_REVOLUTIONS=1
MAX_CO=0.5
VOLUME_WRITE_PER_REV=0.5
PURGE_WRITE=6
MAX_CASE_GB=20

MOVIE_DURATION_SEC=10
MOVIE_FPS=16
MOVIE_WIDTH=1280
MOVIE_HEIGHT=720
Q_ISO_VALUE=0

OF_MODE=docker
OF_IMAGE=openfoam/openfoam11-paraview510:latest
