# =============================================================================
# Propulsor / pumpjet CFD pipeline configuration
# Copy to config.env and edit. Source automatically by pipeline scripts.
# =============================================================================

# --- Paths -------------------------------------------------------------------
# Directory that will hold the OpenFOAM case (created if missing)
CASE_DIR="${CASE_DIR:-$PWD/cases/my_pumpjet}"

# Path to watertight STL of the *rotating* assembly (rotor / pumpjet rotor)
# Units: metres (scale with STL_SCALE if your CAD is in mm)
ROTOR_STL="${ROTOR_STL:-}"

# Optional stationary parts (duct, stator, shroud). Leave empty if none.
# Space-separated list of STL paths.
STATOR_STLS="${STATOR_STLS:-}"

# Convert CAD millimetres → metres: 0.001 for mm, 1.0 if already metres
STL_SCALE="${STL_SCALE:-1.0}"

# --- Rotation model ----------------------------------------------------------
# mrf     — static mesh + Multiple Reference Frame (default; robust for pumpjets)
# sliding — solidBody mesh motion + non-conformal couples (true rotation; needs good mesh)
ROTATION_MODE="${ROTATION_MODE:-mrf}"

# --- Operating point ---------------------------------------------------------
# Rotation rate [rpm] and axis through ORIGIN
RPM="${RPM:-1500}"
# Rotation axis unit vector (x y z). Pumpjets often use (1 0 0) or (0 1 0).
# IMPORTANT: keep vectors in quotes.
ROT_AXIS="${ROT_AXIS:-"0 1 0"}"
ROT_ORIGIN="${ROT_ORIGIN:-"0 0 0"}"

# Freestream / advance velocity [m/s] as (Ux Uy Uz)
# Should be roughly aligned with the propulsor axis (inflow toward the rotor).
U_INF="${U_INF:-"0 -5 0"}"

# Kinematic viscosity [m^2/s] (water ~1e-6, air ~1.5e-5)
NU="${NU:-1e-6}"

# Density for force reporting only (incompressible solver is kinematic; set
# rhoInf to actual density if you want dimensional forces in N, N·m)
RHO_INF="${RHO_INF:-1}"

# --- Domain (auto from STL bbox unless overridden) ---------------------------
# Domain half-length factors relative to characteristic rotor diameter D
# Upstream / downstream / radial extent multipliers
DOMAIN_UPSTREAM_D="${DOMAIN_UPSTREAM_D:-2.0}"
DOMAIN_DOWNSTREAM_D="${DOMAIN_DOWNSTREAM_D:-4.0}"
DOMAIN_RADIUS_D="${DOMAIN_RADIUS_D:-2.0}"

# Rotating-zone cylinder radius factor (× D/2). Must enclose the rotor with margin.
ROTZONE_RADIUS_FACTOR="${ROTZONE_RADIUS_FACTOR:-1.15}"
# Rotating-zone half-length factor along axis (× D)
ROTZONE_HALF_LENGTH_D="${ROTZONE_HALF_LENGTH_D:-0.6}"

# Manual override of characteristic diameter [m]. Empty = auto from rotor bbox.
CHAR_DIAMETER="${CHAR_DIAMETER:-}"

# --- Mesh resolution presets -------------------------------------------------
# demo | engineering | fine | custom
MESH_PRESET="${MESH_PRESET:-demo}"

# Used when MESH_PRESET=custom (and as overrides if set for any preset)
# Background blockMesh cells along (axial, radial-ish, span) — see apply script
BLOCK_NX="${BLOCK_NX:-}"
BLOCK_NY="${BLOCK_NY:-}"
BLOCK_NZ="${BLOCK_NZ:-}"
# snappy surface/feature/region levels
REFINE_ROTOR_MIN="${REFINE_ROTOR_MIN:-}"
REFINE_ROTOR_MAX="${REFINE_ROTOR_MAX:-}"
REFINE_STATOR_MIN="${REFINE_STATOR_MIN:-}"
REFINE_STATOR_MAX="${REFINE_STATOR_MAX:-}"
REFINE_ROTZONE="${REFINE_ROTZONE:-}"
MAX_GLOBAL_CELLS="${MAX_GLOBAL_CELLS:-}"
MAX_LOCAL_CELLS="${MAX_LOCAL_CELLS:-}"

# Parallel ranks for mesh + solve (demo preset also defaults to 4)
NPROCS="${NPROCS:-4}"

# --- Transient run -----------------------------------------------------------
# Number of rotor revolutions to simulate (physical time = N_REV * 60/RPM)
N_REVOLUTIONS="${N_REVOLUTIONS:-2}"

# Max Courant number (adjustable Δt). Prefer ≤1 for MRF demos; ≤2 for sliding.
MAX_CO="${MAX_CO:-1}"

# Sparse volume field write interval as fraction of one revolution (disk saver).
# Example: 0.5 → write volume fields twice per revolution.
VOLUME_WRITE_PER_REV="${VOLUME_WRITE_PER_REV:-0.5}"
PURGE_WRITE="${PURGE_WRITE:-8}"

# Soft disk budget for the case directory [GB]. Watchdog may stop the run.
MAX_CASE_GB="${MAX_CASE_GB:-50}"

# --- Movie -------------------------------------------------------------------
# Target playback length [s] of the MP4 (10 / 30 / 60 typical)
MOVIE_DURATION_SEC="${MOVIE_DURATION_SEC:-10}"

# Target frame rate of the MP4
MOVIE_FPS="${MOVIE_FPS:-16}"

# Resolution of rendered frames
MOVIE_WIDTH="${MOVIE_WIDTH:-1280}"
MOVIE_HEIGHT="${MOVIE_HEIGHT:-720}"

# How many *unique* surface samples to keep for the animation.
# If blank: MOVIE_DURATION_SEC * MOVIE_FPS (e.g. 30*16=480 frames).
# Surface write interval is derived from endTime / N_FRAMES.
MOVIE_FRAMES="${MOVIE_FRAMES:-}"

# Primary colour field on the cut plane: U or p
MOVIE_FIELD="${MOVIE_FIELD:-U}"

# Optional iso-surface of Q-criterion (0 to disable)
Q_ISO_VALUE="${Q_ISO_VALUE:-500}"

# --- OpenFOAM execution ------------------------------------------------------
# How to invoke OpenFOAM commands:
#   docker  — use Docker image (default; works on this VM)
#   native  — foam already sourced in the shell
OF_MODE="${OF_MODE:-docker}"
OF_IMAGE="${OF_IMAGE:-openfoam/openfoam11-paraview510:latest}"
# Host wrapper if you have one (optional). Else pipeline uses docker run.
OPENFOAM_BIN="${OPENFOAM_BIN:-}"
